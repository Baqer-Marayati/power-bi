.DS_Store
**/.DS_Store

# Local Cursor MCP / tooling (not portfolio source)
.cursor/mcp/
.cursor/mcp.json
Exports/Server Packages/*.zip
!Exports/Server Packages/.gitkeep
Reports/*/Exports/Server Packages/archive/
Reports/*/Exports/Server Packages/latest/*.zip
Reports/*/Records/screenshots/*.png
Reports/*/Module/Records/Screenshots/*.png
Reports/*/Module/Records/screenshots/*.png

# Power BI semantic model data cache (should never be committed — always refresh on open)
**/.pbi/cache.abf
**/.pbi/localSettings.json

# Ad-hoc Cursor chat captures (keep folder; do not commit binaries)
Shared/ChatContext/images/*
!Shared/ChatContext/images/.gitkeep

# SAP export — local credentials (use credentials.env.example as a template)
Shared/SAP Export Pipeline/set_credentials.sh
Shared/SAP Export Pipeline/credentials.env
Shared/SAP Export Pipeline/.env

# Power BI REST API — local automation credentials (never commit)
Portfolio/scripts/powerbi-api-local.env

# SAP HANA — local read-only connection for dev/metadata checks (never commit)
Portfolio/scripts/hana-b1-readonly.env
