	partition Fact_StockCoverPolicy = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "WITH#(lf)  SalesLines AS (#(lf)      SELECT B.""ItemCode"" AS ""ItemCode"", A.""DocDate"" AS ""DocDate"",#(lf)             B.""Quantity""            AS ""Qty"",#(lf)             B.""StockValue""          AS ""COGS"",#(lf)             B.""LineTotal""           AS ""SalesValue""#(lf)      FROM ""PAPERENTITY"".""OINV"" A JOIN ""PAPERENTITY"".""INV1"" B ON A.""DocEntry""=B.""DocEntry""#(lf)      WHERE A.""CANCELED""='N' AND A.""DocType""='I'#(lf)        AND IFNULL(B.""ItemCode"",'')<>''#(lf)        AND A.""DocDate"" >= '2024-01-01'#(lf)      UNION ALL#(lf)      SELECT B.""ItemCode"" AS ""ItemCode"", A.""DocDate"" AS ""DocDate"",#(lf)             B.""Quantity"" * -1 AS ""Qty"", B.""StockValue"" * -1 AS ""COGS"", B.""LineTotal"" * -1 AS ""SalesValue""#(lf)      FROM ""PAPERENTITY"".""ORIN"" A JOIN ""PAPERENTITY"".""RIN1"" B ON A.""DocEntry""=B.""DocEntry""#(lf)      WHERE A.""CANCELED""='N' AND A.""DocType""='I'#(lf)        AND IFNULL(B.""ItemCode"",'')<>''#(lf)        AND A.""DocDate"" >= '2024-01-01'#(lf)      