	partition PayablesFact = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "WITH OpenBP AS (#(lf)    SELECT#(lf)        J.""ShortName""                                     AS ""CardCode"",#(lf)        C.""CardName""                                      AS ""CardName"",#(lf)        C.""U_PartnerType""                                 AS ""VendorType"",#(lf)        OJ.""TransId""                                      AS ""TransId"",#(lf)        OJ.""TransType""                                    AS ""TransType"",#(lf)        OJ.""RefDate""                                      AS ""RefDate"",#(lf)        J.""DueDate""                                       AS ""DueDate"",#(lf)        OJ.""BaseRef""                                      AS ""BaseRef"",#(lf)        COALESCE(OJ.""Memo"", J.""LineMemo"")                 AS ""Memo"",#(lf)        CASE#(lf)            WHEN COALESCE(J.""FCCurrency"", '') = ''#(lf)            THEN (COALESCE(J.""BalDueCred"",0) - COALESCE(J.""BalDueDeb"",0))#(lf)            ELSE (COALESCE(J.""BalFcCred"",0) - COALESCE(J.""BalFcDeb"",0))#(lf)        END                                               AS ""OpenAmount"",#(lf)        DAYS_BETWEEN(J.""DueDate"", CURRENT_DATE)           AS ""DaysPastDue"",#(lf)        COALESCE(NULLIF(J.""FCCurrency"", ''), 'IQD')       AS ""FCCurrency""#(lf)    FROM ""CANON"".""JDT1"" J#(lf)    JOIN ""CANON"".""OJDT"" OJ#(lf)        ON OJ.""TransId"" = J.""TransId""#(lf)    JOIN ""CANON"".""OCRD"" C#(lf)        ON C.""CardCode"" = J.""ShortName""#(lf)       AND C.""CardType"" = 'S'#(lf)    WHERE#(lf)        (COALESCE(J.""BalDueDeb"",0) <> 0 OR COALESCE(J.""BalDueCred"",0) <> 0)#(lf)        AND J.""Account"" IN ('210101010101', '210101010102', '210101010103')#(lf))#(lf)SELECT#(lf)    ""CardCode"",#(lf)    ""CardName"",#(lf)    ""VendorType"",#(lf)    ""TransId"",#(lf)    ""TransType"",#(lf)    ""RefDate"",#(lf)    ""DueDate"",#(lf)    ""BaseRef"",#(lf)    ""Memo"",#(lf)    ""OpenAmount"",#(lf)    ""DaysPastDue"",#(lf)    ""FCCurrency"",#(lf)    CASE WHEN ""DaysPastDue"" < 0 THEN ""OpenAmount"" ELSE 0 END AS ""FutureRemit"",#(lf)    CASE WHEN ""DaysPastDue"" BETWEEN 0  AND 30  THEN ""OpenAmount"" ELSE 0 END AS ""B0_30"",#(lf)    CASE WHEN ""DaysPastDue"" BETWEEN 31 AND 60  THEN ""OpenAmount"" ELSE 0 END AS ""B31_60"",#(lf)    CASE WHEN ""DaysPastDue"" BETWEEN 61 AND 90  THEN ""OpenAmount"" ELSE 0 END AS ""B61_90"",#(lf)    CASE WHEN ""DaysPastDue"" BETWEEN 91 AND 120 THEN ""OpenAmount"" ELSE 0 END AS ""B91_120"",#(lf)    CASE WHEN ""DaysPastDue"" >= 121            THEN ""OpenAmount"" ELSE 0 END AS ""B121Plus""#(lf)FROM OpenBP#(lf)WHERE ""OpenAmount"" <> 0;")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

