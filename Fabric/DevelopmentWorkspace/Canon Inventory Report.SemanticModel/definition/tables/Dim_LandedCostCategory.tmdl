table Dim_LandedCostCategory
	lineageTag: b0c0d0e0-f001-4001-8001-000000000001

	column LandedCostCode
		dataType: string
		lineageTag: b0c0d0e0-f001-4001-8001-000000000002
		summarizeBy: none
		sourceColumn: LandedCostCode

		annotation SummarizationSetBy = Automatic

	column LandedCostName
		dataType: string
		lineageTag: b0c0d0e0-f001-4001-8001-000000000003
		summarizeBy: none
		sourceColumn: LandedCostName

		annotation SummarizationSetBy = Automatic

	column ReportingCategory
		dataType: string
		lineageTag: b0c0d0e0-f001-4001-8001-000000000004
		summarizeBy: none
		sourceColumn: ReportingCategory

		annotation SummarizationSetBy = Automatic

	column CategorySort
		dataType: int64
		formatString: 0
		lineageTag: b0c0d0e0-f001-4001-8001-000000000005
		summarizeBy: none
		sourceColumn: CategorySort

		annotation SummarizationSetBy = Automatic

	partition Dim_LandedCostCategory = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    'BASE' AS ""LandedCostCode"",#(lf)    'Supplier base' AS ""LandedCostName"",#(lf)    'Supplier base' AS ""ReportingCategory"",#(lf)    1 AS ""CategorySort""#(lf)FROM DUMMY#(lf)UNION ALL#(lf)SELECT#(lf)    T0.""AlcCode"" AS ""LandedCostCode"",#(lf)    T0.""AlcName"" AS ""LandedCostName"",#(lf)    CASE#(lf)        WHEN LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%freight%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%shipping%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%transport%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%delivery%' THEN 'Transport'#(lf)        WHEN LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%unload%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%handling%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%terminal%' THEN 'Unloading'#(lf)        WHEN LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%custom%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%duty%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%tax%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%vat%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%excise%' THEN 'Tax / duty'#(lf)        ELSE 'Other'#(lf)    END AS ""ReportingCategory"",#(lf)    CASE#(lf)        WHEN LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%freight%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%shipping%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%transport%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%delivery%' THEN 2#(lf)        WHEN LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%unload%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%handling%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '')) LIKE '%terminal%' THEN 3#(lf)        WHEN LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%custom%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%duty%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%tax%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%vat%'#(lf)          OR LOWER(COALESCE(T0.""AlcName"", '') || ' ' || COALESCE(T0.""AlcCode"", '') || ' ' || COALESCE(T0.""CostCateg"", '')) LIKE '%excise%' THEN 4#(lf)        ELSE 5#(lf)    END AS ""CategorySort""#(lf)FROM ""CANON"".""OALC"" T0")
				in
				    Source

	annotation PBI_ResultType = Table

