	partition Fact_StockMovement = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""ItemCode"",#(lf)    T0.""DocDate"",#(lf)    T0.""TransType"",#(lf)    CASE#(lf)        WHEN T0.""TransType"" = 13 THEN 'A/R Invoice'#(lf)        WHEN T0.""TransType"" = 14 THEN 'A/R Credit Note'#(lf)        WHEN T0.""TransType"" = 15 THEN 'Delivery'#(lf)        WHEN T0.""TransType"" = 16 THEN 'Return'#(lf)        WHEN T0.""TransType"" = 18 THEN 'Goods Receipt PO'#(lf)        WHEN T0.""TransType"" = 19 THEN 'Goods Return'#(lf)        WHEN T0.""TransType"" = 20 THEN 'Goods Receipt'#(lf)        WHEN T0.""TransType"" = 59 THEN 'Goods Receipt'#(lf)        WHEN T0.""TransType"" = 60 THEN 'Goods Issue'#(lf)        WHEN T0.""TransType"" = 67 THEN 'Transfer'#(lf)        WHEN T0.""TransType"" = 69 THEN 'Material Revaluation'#(lf)        WHEN T0.""TransType"" = 162 THEN 'Inventory Revaluation'#(lf)        WHEN T0.""TransType"" = 310000001 THEN 'Opening Balance'#(lf)        ELSE 'Other'#(lf)    END AS ""TransTypeName"",#(lf)    T0.""InQty"",#(lf)    T0.""OutQty"",#(lf)    T0.""TransValue"",#(lf)    T0.""CogsVal"" AS ""CogsValue"",#(lf)    T0.""Currency"",#(lf)    T0.""Warehouse"" AS ""WhsCode"",#(lf)    CASE#(lf)        WHEN T0.""TransType"" = 13 AND COALESCE(T13.""CANCELED"", 'N') = 'N' AND COALESCE(T13.""DocType"", 'I') = 'I' THEN 1#(lf)        WHEN T0.""TransType"" = 15 AND COALESCE(T15.""CANCELED"", 'N') = 'N' THEN 1#(lf)        WHEN T0.""TransType"" = 14 AND COALESCE(T14.""CANCELED"", 'N') = 'N' AND COALESCE(T14.""DocType"", 'I') = 'I' THEN 1#(lf)        WHEN T0.""TransType"" = 16 AND COALESCE(T16.""CANCELED"", 'N') = 'N' THEN 1#(lf)        ELSE 0#(lf)    END AS ""SalesCogsIncluded""#(lf)FROM ""CANON"".""OINM"" T0#(lf)LEFT JOIN ""CANON"".""OINV"" T13 ON T0.""TransType"" = 13 AND T0.""BASE_REF"" = TO_NVARCHAR(T13.""DocNum"")#(lf)LEFT JOIN ""CANON"".""ODLN"" T15 ON T0.""TransType"" = 15 AND T0.""BASE_REF"" = TO_NVARCHAR(T15.""DocNum"")#(lf)LEFT JOIN ""CANON"".""ORIN"" T14 ON T0.""TransType"" = 14 AND T0.""BASE_REF"" = TO_NVARCHAR(T14.""DocNum"")#(lf)LEFT JOIN ""CANON"".""ORDN"" T16 ON T0.""TransType"" = 16 AND T0.""BASE_REF"" = TO_NVARCHAR(T16.""DocNum"")#(lf)WHERE T0.""DocDate"" >= '2026-01-01'")
				in
				    Source

	annotation PBI_ResultType = Table

