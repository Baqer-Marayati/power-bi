# Power BI remote MCP (Fabric) — Cursor cannot load envFile for HTTP MCP servers.
# Export before launching Cursor from Terminal, or add to your shell profile:
#
#   export POWERBI_REMOTE_MCP_CLIENT_ID="your-entra-app-client-id-guid"
#
# In Entra ID → App registrations → your app → Authentication:
# - Treat as public client (Allow public client flows: Yes) if using PKCE without secret
# - Redirect URI (mobile/desktop or custom): cursor://anysphere.cursor-mcp/oauth/callback
# - Delegated API permission: Power BI Service (or scopes your tenant requires)

POWERBI_REMOTE_MCP_CLIENT_ID=
