{
  "mcpServers": {
    "powerbi-modeling-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/powerbi-modeling-mcp@latest",
        "--start"
      ]
    },
    "powerbi-remote": {
      "type": "http",
      "url": "https://api.fabric.microsoft.com/v1/mcp/powerbi",
      "auth": {
        "CLIENT_ID": "${env:POWERBI_REMOTE_MCP_CLIENT_ID}",
        "scopes": [
          "https://analysis.windows.net/powerbi/api/.default"
        ]
      }
    }
  }
}
