	partition SalesFact = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "/* ===========================================================#(lf)   SalesFact + Warranty + G/L COGS Adjustments#(lf)   -----------------------------------------------------------#(lf)   Logic:#(lf)   - Sales from A/R Invoice + A/R Credit Memo#(lf)   - Stock COGS from INV1/RIN1 StockValue#(lf)   - Warranty COGS from A/P Invoice item SV003#(lf)   - A/P Credit Memo for SV003 reverses warranty cost#(lf)   - Non-item A/R lines on revenue accounts (45..., 46...) stay in Sales#(lf)   - Non-item A/R lines on cost/expense accounts are excluded from Sales#(lf)   - Finance-side COGS adjustments are added from OJDT/JDT1#(lf)#(lf)   IMPORTANT:#(lf)   1) Replace the accounts in GLCOGSAdjustments with your real SAP#(lf)      finance-side COGS adjustment accounts.#(lf)   2) Do NOT include stock COGS accounts already represented by StockValue.#(lf)   3) Do NOT include the warranty account if warranty is already captured#(lf)      by SV003 in OPCH/ORPC, otherwise you will double count it.#(lf)   =========================================================== */#(lf)#(lf)WITH#(lf)InvBase AS (#(lf)    SELECT#(lf)        H.""DocEntry"",#(lf)        H.""DocDate"",#(lf)        H.""CardCode"",#(lf)        H.""SlpCode"",#(lf)        H.""DiscSum""#(lf)    FROM ""CANON"".""OINV"" H#(lf)    WHERE H.""CANCELED"" = 'N'#(lf)),#(lf)InvTotals AS (#(lf)    SELECT#(lf)        L.""DocEntry"",#(lf)        SUM(L.""LineTotal"") AS ""SumLineTotal""#(lf)    FROM ""CANON"".""INV1"" L#(lf)    GROUP BY L.""DocEntry""#(lf)),#(lf)InvLines AS (#(lf)    SELECT#(lf)        B.""DocDate""                                              AS ""DocDate"",#(lf)        C.""U_PartnerType""                                        AS ""BPType"",#(lf)        B.""CardCode""                                             AS ""CardCode"",#(lf)        C.""CardName""                                             AS ""CardName"",#(lf)        B.""SlpCode""                                              AS ""SlpCode"",#(lf)        S.""SlpName""                                              AS ""SalesPerson"",#(lf)        S.""U_SalesDept""                                          AS ""SalesDept"",#(lf)        S.""U_SalesType""                                          AS ""SalesType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL THEN '(No Item)'#(lf)            ELSE L.""ItemCode""#(lf)        END                                                      AS ""ItemCode"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN COALESCE(L.""Dscription"", 'Non-Item Revenue')#(lf)            ELSE COALESCE(I.""ItemName"", L.""Dscription"")#(lf)        END                                                      AS ""ItemName"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN 'Non-Item Revenue'#(lf)            ELSE COALESCE(I.""U_BusinessType"", 'Non-Item Revenue')#(lf)        END                                                      AS ""BusinessType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN 'Non-Item Revenue'#(lf)            ELSE COALESCE(I.""U_GroupType"", 'Non-Item Revenue')#(lf)        END                                                      AS ""U_GroupType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN 'Non-Item Revenue'#(lf)            ELSE COALESCE(I.""U_ProductType"", 'Non-Item Revenue')#(lf)        END                                                      AS ""U_ProductType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN 'Non-Item Revenue'#(lf)            ELSE COALESCE(I.""U_SegmentType"", 'Non-Item Revenue')#(lf)        END                                                      AS ""U_SegmentType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL THEN 0#(lf)            ELSE L.""Quantity""#(lf)        END                                                      AS ""Qty"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NOT NULL THEN#(lf)                (#(lf)                    L.""LineTotal""#(lf)                    + CASE#(lf)                        WHEN T.""SumLineTotal"" = 0 OR T.""SumLineTotal"" IS NULL THEN 0#(lf)                        ELSE (L.""LineTotal"" * B.""DiscSum"" * -1) / T.""SumLineTotal""#(lf)                      END#(lf)                )#(lf)            WHEN L.""ItemCode"" IS NULL#(lf)                 AND COALESCE(L.""LineTotal"", 0) <> 0#(lf)                 AND (L.""AcctCode"" LIKE '45%' OR L.""AcctCode"" LIKE '46%') THEN#(lf)                (#(lf)                    L.""LineTotal""#(lf)                    + CASE#(lf)                        WHEN T.""SumLineTotal"" = 0 OR T.""SumLineTotal"" IS NULL THEN 0#(lf)                        ELSE (L.""LineTotal"" * B.""DiscSum"" * -1) / T.""SumLineTotal""#(lf)                      END#(lf)                )#(lf)            ELSE 0#(lf)        END                                                      AS ""Sales"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL THEN 0#(lf)            ELSE L.""StockValue""#(lf)        END                                                      AS ""COGS""#(lf)#(lf)    FROM InvBase B#(lf)    JOIN ""CANON"".""INV1"" L       ON L.""DocEntry"" = B.""DocEntry""#(lf)    LEFT JOIN InvTotals T       ON T.""DocEntry"" = B.""DocEntry""#(lf)    JOIN ""CANON"".""OCRD"" C       ON C.""CardCode"" = B.""CardCode""#(lf)    LEFT JOIN ""CANON"".""OITM"" I  ON I.""ItemCode"" = L.""ItemCode""#(lf)    LEFT JOIN ""CANON"".""OSLP"" S  ON S.""SlpCode""  = B.""SlpCode""#(lf)    WHERE#(lf)        L.""ItemCode"" IS NOT NULL#(lf)        OR (#(lf)            L.""ItemCode"" IS NULL#(lf)            AND COALESCE(L.""LineTotal"", 0) <> 0#(lf)            AND (L.""AcctCode"" LIKE '45%' OR L.""AcctCode"" LIKE '46%')#(lf)        )#(lf)),#(lf)#(lf)CrBase AS (#(lf)    SELECT#(lf)        H.""DocEntry"",#(lf)        H.""DocDate"",#(lf)        H.""CardCode"",#(lf)        H.""SlpCode"",#(lf)        H.""DiscSum""#(lf)    FROM ""CANON"".""ORIN"" H#(lf)    WHERE H.""CANCELED"" = 'N'#(lf)),#(lf)CrTotals AS (#(lf)    SELECT#(lf)        L.""DocEntry"",#(lf)        SUM(L.""LineTotal"") AS ""SumLineTotal""#(lf)    FROM ""CANON"".""RIN1"" L#(lf)    GROUP BY L.""DocEntry""#(lf)),#(lf)CrLines AS (#(lf)    SELECT#(lf)        B.""DocDate""                                              AS ""DocDate"",#(lf)        C.""U_PartnerType""                                        AS ""BPType"",#(lf)        B.""CardCode""                                             AS ""CardCode"",#(lf)        C.""CardName""                                             AS ""CardName"",#(lf)        B.""SlpCode""                                              AS ""SlpCode"",#(lf)        S.""SlpName""                                              AS ""SalesPerson"",#(lf)        S.""U_SalesDept""                                          AS ""SalesDept"",#(lf)        S.""U_SalesType""                                          AS ""SalesType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL THEN '(No Item)'#(lf)            ELSE L.""ItemCode""#(lf)        END                                                      AS ""ItemCode"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN COALESCE(L.""Dscription"", 'Non-Item Revenue')#(lf)            ELSE COALESCE(I.""ItemName"", L.""Dscription"")#(lf)        END                                                      AS ""ItemName"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN 'Non-Item Revenue'#(lf)            ELSE COALESCE(I.""U_BusinessType"", 'Non-Item Revenue')#(lf)        END                                                      AS ""BusinessType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN 'Non-Item Revenue'#(lf)            ELSE COALESCE(I.""U_GroupType"", 'Non-Item Revenue')#(lf)        END                                                      AS ""U_GroupType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN 'Non-Item Revenue'#(lf)            ELSE COALESCE(I.""U_ProductType"", 'Non-Item Revenue')#(lf)        END                                                      AS ""U_ProductType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL AND L.""AcctCode"" = '4601010101' THEN 'Credit Memo'#(lf)            WHEN L.""ItemCode"" IS NULL THEN 'Non-Item Revenue'#(lf)            ELSE COALESCE(I.""U_SegmentType"", 'Non-Item Revenue')#(lf)        END                                                      AS ""U_SegmentType"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL THEN 0#(lf)            ELSE (L.""Quantity"" * -1)#(lf)        END                                                      AS ""Qty"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NOT NULL THEN#(lf)                (#(lf)                    (L.""LineTotal"" * -1)#(lf)                    + CASE#(lf)                        WHEN T.""SumLineTotal"" = 0 OR T.""SumLineTotal"" IS NULL THEN 0#(lf)                        ELSE (L.""LineTotal"" * B.""DiscSum"") / T.""SumLineTotal""#(lf)                      END#(lf)                )#(lf)            WHEN L.""ItemCode"" IS NULL#(lf)                 AND COALESCE(L.""LineTotal"", 0) <> 0#(lf)                 AND (L.""AcctCode"" LIKE '45%' OR L.""AcctCode"" LIKE '46%') THEN#(lf)                (#(lf)                    (L.""LineTotal"" * -1)#(lf)                    + CASE#(lf)                        WHEN T.""SumLineTotal"" = 0 OR T.""SumLineTotal"" IS NULL THEN 0#(lf)                        ELSE (L.""LineTotal"" * B.""DiscSum"") / T.""SumLineTotal""#(lf)                      END#(lf)                )#(lf)            ELSE 0#(lf)        END                                                      AS ""Sales"",#(lf)#(lf)        CASE#(lf)            WHEN L.""ItemCode"" IS NULL THEN 0#(lf)            ELSE (L.""StockValue"" * -1)#(lf)        END                                                      AS ""COGS""#(lf)#(lf)    FROM CrBase B#(lf)    JOIN ""CANON"".""RIN1"" L       ON L.""DocEntry"" = B.""DocEntry""#(lf)    LEFT JOIN CrTotals T        ON T.""DocEntry"" = B.""DocEntry""#(lf)    JOIN ""CANON"".""OCRD"" C       ON C.""CardCode"" = B.""CardCode""#(lf)    LEFT JOIN ""CANON"".""OITM"" I  ON I.""ItemCode"" = L.""ItemCode""#(lf)    LEFT JOIN ""CANON"".""OSLP"" S  ON S.""SlpCode""  = B.""SlpCode""#(lf)    WHERE#(lf)        L.""ItemCode"" IS NOT NULL#(lf)        OR (#(lf)            L.""ItemCode"" IS NULL#(lf)            AND COALESCE(L.""LineTotal"", 0) <> 0#(lf)            AND (L.""AcctCode"" LIKE '45%' OR L.""AcctCode"" LIKE '46%')#(lf)        )#(lf)),#(lf)#(lf)/* ===========================================================#(lf)   Warranty A/P Invoices (positive COGS)#(lf)   =========================================================== */#(lf)WarrantyAP AS (#(lf)    SELECT#(lf)        H.""DocDate""                              AS ""DocDate"",#(lf)        'Warranty'                               AS ""BPType"",#(lf)        'WARRANTY'                               AS ""CardCode"",#(lf)        'Warranty Provision'                     AS ""CardName"",#(lf)        -1                                       AS ""SlpCode"",#(lf)        'Warranty'                               AS ""SalesPerson"",#(lf)        'Warranty'                               AS ""SalesDept"",#(lf)        'Warranty'                               AS ""SalesType"",#(lf)        L.""ItemCode""                             AS ""ItemCode"",#(lf)        COALESCE(I.""ItemName"", L.""Dscription"")   AS ""ItemName"",#(lf)        COALESCE(I.""U_BusinessType"", 'Warranty') AS ""BusinessType"",#(lf)        COALESCE(I.""U_GroupType"", 'Warranty')    AS ""U_GroupType"",#(lf)        COALESCE(I.""U_ProductType"", 'Warranty')  AS ""U_ProductType"",#(lf)        COALESCE(I.""U_SegmentType"", 'Warranty')  AS ""U_SegmentType"",#(lf)        0                                        AS ""Qty"",#(lf)        0                                        AS ""Sales"",#(lf)        SUM(L.""LineTotal"")                       AS ""COGS""#(lf)    FROM ""CANON"".""OPCH"" H#(lf)    JOIN ""CANON"".""PCH1"" L       ON L.""DocEntry"" = H.""DocEntry""#(lf)    LEFT JOIN ""CANON"".""OITM"" I  ON I.""ItemCode"" = L.""ItemCode""#(lf)    WHERE H.""CANCELED"" = 'N'#(lf)      AND L.""ItemCode"" = 'SV003'#(lf)    GROUP BY#(lf)        H.""DocDate"",#(lf)        L.""ItemCode"",#(lf)        COALESCE(I.""ItemName"", L.""Dscription""),#(lf)        COALESCE(I.""U_BusinessType"", 'Warranty'),#(lf)        COALESCE(I.""U_GroupType"", 'Warranty'),#(lf)        COALESCE(I.""U_ProductType"", 'Warranty'),#(lf)        COALESCE(I.""U_SegmentType"", 'Warranty')#(lf)),#(lf)#(lf)/* ===========================================================#(lf)   Warranty A/P Credit Memos (negative COGS)#(lf)   =========================================================== */#(lf)WarrantyAPCredit AS (#(lf)    SELECT#(lf)        H.""DocDate""                              AS ""DocDate"",#(lf)        'Warranty'                               AS ""BPType"",#(lf)        'WARRANTY'                               AS ""CardCode"",#(lf)        'Warranty Provision'                     AS ""CardName"",#(lf)        -1                                       AS ""SlpCode"",#(lf)        'Warranty'                               AS ""SalesPerson"",#(lf)        'Warranty'                               AS ""SalesDept"",#(lf)        'Warranty'                               AS ""SalesType"",#(lf)        L.""ItemCode""                             AS ""ItemCode"",#(lf)        COALESCE(I.""ItemName"", L.""Dscription"")   AS ""ItemName"",#(lf)        COALESCE(I.""U_BusinessType"", 'Warranty') AS ""BusinessType"",#(lf)        COALESCE(I.""U_GroupType"", 'Warranty')    AS ""U_GroupType"",#(lf)        COALESCE(I.""U_ProductType"", 'Warranty')  AS ""U_ProductType"",#(lf)        COALESCE(I.""U_SegmentType"", 'Warranty')  AS ""U_SegmentType"",#(lf)        0                                        AS ""Qty"",#(lf)        0                                        AS ""Sales"",#(lf)        SUM(L.""LineTotal"") * -1                  AS ""COGS""#(lf)    FROM ""CANON"".""ORPC"" H#(lf)    JOIN ""CANON"".""RPC1"" L       ON L.""DocEntry"" = H.""DocEntry""#(lf)    LEFT JOIN ""CANON"".""OITM"" I  ON I.""ItemCode"" = L.""ItemCode""#(lf)    WHERE H.""CANCELED"" = 'N'#(lf)      AND L.""ItemCode"" = 'SV003'#(lf)    GROUP BY#(lf)        H.""DocDate"",#(lf)        L.""ItemCode"",#(lf)        COALESCE(I.""ItemName"", L.""Dscription""),#(lf)        COALESCE(I.""U_BusinessType"", 'Warranty'),#(lf)        COALESCE(I.""U_GroupType"", 'Warranty'),#(lf)        COALESCE(I.""U_ProductType"", 'Warranty'),#(lf)        COALESCE(I.""U_SegmentType"", 'Warranty')#(lf)),#(lf)#(lf)/* ===========================================================#(lf)   G/L-based COGS adjustments#(lf)   -----------------------------------------------------------#(lf)   REPLACE the account list below with your actual finance-side#(lf)   COGS adjustment accounts.#(lf)   Example uses placeholders only.#(lf)   =========================================================== */#(lf)GLCOGSAdjustments AS (#(lf)    SELECT#(lf)        H.""RefDate""                            AS ""DocDate"",#(lf)        'Finance COGS'                         AS ""BPType"",#(lf)        'GL-COGS'                              AS ""CardCode"",#(lf)        'Finance COGS'                         AS ""CardName"",#(lf)        -1                                     AS ""SlpCode"",#(lf)        'Finance COGS'                         AS ""SalesPerson"",#(lf)        'Finance COGS'                         AS ""SalesDept"",#(lf)        'Finance COGS'                         AS ""SalesType"",#(lf)        '(GL COGS)'                            AS ""ItemCode"",#(lf)        A.""AcctName""                           AS ""ItemName"",#(lf)        'Finance COGS'                         AS ""BusinessType"",#(lf)        'Finance COGS'                         AS ""U_GroupType"",#(lf)        'Finance COGS'                         AS ""U_ProductType"",#(lf)        'Finance COGS'                         AS ""U_SegmentType"",#(lf)        0                                      AS ""Qty"",#(lf)        0                                      AS ""Sales"",#(lf)        SUM(COALESCE(L.""Debit"", 0) - COALESCE(L.""Credit"", 0)) AS ""COGS""#(lf)    FROM ""CANON"".""OJDT"" H#(lf)    JOIN ""CANON"".""JDT1"" L ON L.""TransId"" = H.""TransId""#(lf)    LEFT JOIN ""CANON"".""OACT"" A ON A.""AcctCode"" = L.""Account""#(lf)    WHERE#(lf)        L.""Account"" IN (#(lf)            'REPLACE_WITH_ACCOUNT_1',#(lf)            'REPLACE_WITH_ACCOUNT_2',#(lf)            'REPLACE_WITH_ACCOUNT_3'#(lf)        )#(lf)    GROUP BY#(lf)        H.""RefDate"",#(lf)        A.""AcctName""#(lf)),#(lf)#(lf)BaseData AS (#(lf)    SELECT * FROM InvLines#(lf)    UNION ALL#(lf)    SELECT * FROM CrLines#(lf)    UNION ALL#(lf)    SELECT * FROM WarrantyAP#(lf)    UNION ALL#(lf)    SELECT * FROM WarrantyAPCredit#(lf)    UNION ALL#(lf)    SELECT * FROM GLCOGSAdjustments#(lf))#(lf)#(lf)SELECT#(lf)    ""DocDate"",#(lf)    ""BPType"",#(lf)    ""CardCode"",#(lf)    ""CardName"",#(lf)    ""SlpCode"",#(lf)    ""SalesPerson"",#(lf)    ""SalesDept"",#(lf)    ""SalesType"",#(lf)    ""BusinessType"",#(lf)    ""U_GroupType"",#(lf)    ""U_ProductType"",#(lf)    ""U_SegmentType"",#(lf)    ""ItemCode"",#(lf)    ""ItemName"",#(lf)    SUM(""Qty"")   AS ""Qty"",#(lf)    SUM(""Sales"") AS ""Sales"",#(lf)    SUM(""COGS"")  AS ""COGS""#(lf)FROM BaseData#(lf)GROUP BY#(lf)    ""DocDate"",#(lf)    ""BPType"",#(lf)    ""CardCode"",#(lf)    ""CardName"",#(lf)    ""SlpCode"",#(lf)    ""SalesPerson"",#(lf)    ""SalesDept"",#(lf)    ""SalesType"",#(lf)    ""BusinessType"",#(lf)    ""U_GroupType"",#(lf)    ""U_ProductType"",#(lf)    ""U_SegmentType"",#(lf)    ""ItemCode"",#(lf)    ""ItemName"";")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

