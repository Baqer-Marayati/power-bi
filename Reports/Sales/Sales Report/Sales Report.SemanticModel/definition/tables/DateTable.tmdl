		annotation SummarizationSetBy = Automatic

	partition DateTable = calculated
		mode: import
		source =
				
				VAR MinDate0 =
				    MINX ( ALL ( SalesFact ), SalesFact[DocDate] )
				VAR MaxDate0 =
				    MAXX ( ALL ( SalesFact ), SalesFact[DocDate] )
				
				VAR StartDate =
				    DATE ( YEAR ( MinDate0 ), 1, 1 )
				VAR EndDate =
				    MAX ( DATE ( YEAR ( MaxDate0 ), 12, 31 ), TODAY() )
				
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( StartDate, EndDate ),
				    "Year", YEAR ( [Date] ),
				    "MonthNumber", MONTH ( [Date] ),
				    "Day", DAY ( [Date] ),
				    "Month", FORMAT ( [Date], "MMM" ),
				    "MonthYear", FORMAT ( [Date], "MMM YYYY" ),
				    "YearMonth", FORMAT ( [Date], "YYYY-MM" ),
				    "Quarter", "Q" & FORMAT ( [Date], "Q" ),
				    "YearQuarter", FORMAT ( [Date], "YYYY" ) & "-Q" & FORMAT ( [Date], "Q" ),
				    "YearMonthKey", YEAR ( [Date] ) * 100 + MONTH ( [Date] ),
				    "QuarterKey", YEAR ( [Date] ) * 10 + QUARTER ( [Date] )
				)

	annotation PBI_Id = 19ce0c01185d462ba5c1015d334af2d0

