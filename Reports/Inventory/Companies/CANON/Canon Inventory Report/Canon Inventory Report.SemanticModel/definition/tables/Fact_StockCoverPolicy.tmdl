	column Value =
			VAR _unit =
			    COALESCE ( Fact_StockCoverPolicy[AvgItemCost], 0 )
			RETURN
			    SWITCH (
			        TRUE (),
			        Fact_StockCoverPolicy[StockCoverStatus] = "Under Stock",
			            Fact_StockCoverPolicy[SuggestedReorderQty] * _unit,
			        Fact_StockCoverPolicy[StockCoverStatus] = "Over Stock",
			            Fact_StockCoverPolicy[ExcessQty] * _unit,
			        Fact_StockCoverPolicy[StockCoverStatus] = "Equal / Healthy",
			            Fact_StockCoverPolicy[TotalItemCost],
			        Fact_StockCoverPolicy[StockCoverStatus] = "No Sales Stock",
			            Fact_StockCoverPolicy[TotalItemCost],
			        Fact_StockCoverPolicy[StockCoverStatus] = "No Sales / No Stock",
			            0,
			        0
			    )
		dataType: double
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: cc000000-0000-0000-0000-000000000028
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

