	partition Fact_ServiceParts = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)  L.""SrcvCallID"" AS ""CallID"",#(lf)  D.""DocEntry"" AS ""DeliveryDocEntry"",#(lf)  D.""LineNum"",#(lf)  D.""ItemCode"",#(lf)  D.""Dscription"" AS ""Description"",#(lf)  D.""Quantity"",#(lf)  D.""Price"",#(lf)  D.""LineTotal"",#(lf)  D.""Project"" AS ""ProjectCode"",#(lf)  D.""TaxCode"",#(lf)  H.""DocDate"" AS ""DeliveryDate"",#(lf)  H.""CardCode"" AS ""CustomerCode""#(lf)FROM ""CANON"".""SCL4"" L#(lf)INNER JOIN ""CANON"".""ODLN"" H ON L.""DocAbs"" = H.""DocEntry""#(lf)INNER JOIN ""CANON"".""DLN1"" D ON H.""DocEntry"" = D.""DocEntry""#(lf)WHERE L.""PartType"" = 'N'")
				in
				    Source

	annotation PBI_ResultType = Table

