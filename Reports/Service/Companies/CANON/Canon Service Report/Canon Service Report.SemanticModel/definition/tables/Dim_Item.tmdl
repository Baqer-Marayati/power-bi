table Dim_Item
	lineageTag: d1a00004-0001-4000-a004-000000000001

	column ItemCode
		dataType: string
		lineageTag: d1a00004-0001-4000-a004-000000000002
		summarizeBy: none
		sourceColumn: ItemCode

		annotation SummarizationSetBy = Automatic

	column ItemName
		dataType: string
		lineageTag: d1a00004-0001-4000-a004-000000000003
		summarizeBy: none
		sourceColumn: ItemName

		annotation SummarizationSetBy = Automatic

	column ItemGroupCode
		dataType: int64
		formatString: 0
		lineageTag: d1a00004-0001-4000-a004-000000000004
		summarizeBy: none
		sourceColumn: ItemGroupCode

		annotation SummarizationSetBy = Automatic

	column ItemGroupName
		dataType: string
		lineageTag: d1a00004-0001-4000-a004-000000000005
