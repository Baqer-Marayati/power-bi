	column MachineClass
		dataType: string
		lineageTag: d1a00004-0001-4000-a004-000000000006
		summarizeBy: none
		sourceColumn: MachineClass

		annotation SummarizationSetBy = Automatic

	partition Dim_Item = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)  I.""ItemCode"",#(lf)  I.""ItemName"",#(lf)  I.""ItmsGrpCod"" AS ""ItemGroupCode"",#(lf)  G.""ItmsGrpNam"" AS ""ItemGroupName"",#(lf)  CASE#(lf)    WHEN G.""ItmsGrpNam"" LIKE 'B2B - IPS%' THEN 'Production'#(lf)    WHEN G.""ItmsGrpNam"" = '#N/A' THEN 'Production'#(lf)    WHEN G.""ItmsGrpCod"" = 139 THEN 'Production'#(lf)    WHEN G.""ItmsGrpNam"" LIKE 'B2B - DS Copier%' THEN 'Office'#(lf)    WHEN G.""ItmsGrpNam"" LIKE 'B2C%' THEN 'Consumer'#(lf)    WHEN G.""ItmsGrpCod"" IN (172,173,174,175,176,177) THEN 'Service'#(lf)    ELSE 'Other'#(lf)  END AS ""MachineClass""#(lf)FROM ""CANON"".""OITM"" I#(lf)LEFT JOIN ""CANON"".""OITB"" G ON I.""ItmsGrpCod"" = G.""ItmsGrpCod""")
				in
				    Source

	annotation PBI_ResultType = Table

