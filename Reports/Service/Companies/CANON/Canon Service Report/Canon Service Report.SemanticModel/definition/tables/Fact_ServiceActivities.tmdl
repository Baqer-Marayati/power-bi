	partition Fact_ServiceActivities = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)  A.""SrcvCallID"" AS ""CallID"",#(lf)  A.""Line"" AS ""ActivityLine"",#(lf)  A.""Technician"" AS ""TechnicianKey"",#(lf)  A.""HandledBy"" AS ""HandledByKey"",#(lf)  A.""StartDate"",#(lf)  A.""StartTime"",#(lf)  A.""EndTime"",#(lf)  A.""Duration"",#(lf)  A.""DurType"" AS ""DurationType"",#(lf)  CASE A.""DurType""#(lf)    WHEN 'H' THEN A.""Duration""#(lf)    WHEN 'M' THEN A.""Duration"" / 60.0#(lf)    WHEN 'D' THEN A.""Duration"" * 8.0#(lf)    ELSE A.""Duration""#(lf)  END AS ""DurationHours"",#(lf)  A.""Remark"",#(lf)  S.""customer"" AS ""CustomerCode"",#(lf)  S.""insID"" AS ""EquipmentKey"",#(lf)  S.""itemCode"" AS ""ItemCode""#(lf)FROM ""CANON"".""SCL6"" A#(lf)INNER JOIN ""CANON"".""OSCL"" S ON A.""SrcvCallID"" = S.""callID""")
				in
				    Source

	annotation PBI_ResultType = Table

