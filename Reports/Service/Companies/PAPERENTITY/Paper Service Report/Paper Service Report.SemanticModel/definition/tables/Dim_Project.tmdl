	partition Dim_Project = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)  P.""PrjCode"" AS ""ProjectCode"",#(lf)  P.""PrjName"" AS ""ProjectName"",#(lf)  P.""Active"" AS ""IsActive""#(lf)FROM ""PAPERENTITY"".""OPRJ"" P")
				in
				    Source

	annotation PBI_ResultType = Table

