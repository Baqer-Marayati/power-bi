table Dim_Project
	lineageTag: d1a00006-0001-4000-a006-000000000001

	column ProjectCode
		dataType: string
		lineageTag: d1a00006-0001-4000-a006-000000000002
		summarizeBy: none
		sourceColumn: ProjectCode

		annotation SummarizationSetBy = Automatic

	column ProjectName
		dataType: string
		lineageTag: d1a00006-0001-4000-a006-000000000003
		summarizeBy: none
		sourceColumn: ProjectName

		annotation SummarizationSetBy = Automatic

	column IsActive
