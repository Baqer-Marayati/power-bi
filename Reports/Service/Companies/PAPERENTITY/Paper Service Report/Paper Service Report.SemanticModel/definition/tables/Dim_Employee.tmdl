	partition Dim_Employee = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)  E.""empID"" AS ""EmployeeKey"",#(lf)  TRIM(E.""firstName"") || ' ' || TRIM(E.""lastName"") AS ""EmployeeName"",#(lf)  TRIM(E.""firstName"") AS ""FirstName"",#(lf)  TRIM(E.""lastName"") AS ""LastName"",#(lf)  COALESCE(D.""Name"", 'Unknown') AS ""Department"",#(lf)  COALESCE(P.""name"", 'Unknown') AS ""Position"",#(lf)  CASE#(lf)    WHEN E.""empID"" IN (66,67,68,69,70,71) THEN 'Production'#(lf)    WHEN E.""empID"" IN (72,73,74,75,76,77,78) THEN 'Office'#(lf)    WHEN E.""empID"" = 80 THEN 'Call Center'#(lf)    ELSE 'Other'#(lf)  END AS ""Team"",#(lf)  CASE#(lf)    WHEN E.""empID"" = 80 THEN 'Dispatcher'#(lf)    ELSE 'Technician'#(lf)  END AS ""Role""#(lf)FROM ""PAPERENTITY"".""OHEM"" E#(lf)LEFT JOIN ""PAPERENTITY"".""OUDP"" D ON E.""dept"" = D.""Code""#(lf)LEFT JOIN ""PAPERENTITY"".""OHPS"" P ON E.""position"" = P.""posID""#(lf)WHERE E.""empID"" IN (66,67,68,69,70,71,72,73,74,75,76,77,78,80)")
				in
				    Source

	annotation PBI_ResultType = Table

