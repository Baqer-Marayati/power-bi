	partition Fact_ServiceRevenue = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)  I.""DocEntry"",#(lf)  H.""DocNum"",#(lf)  I.""LineNum"",#(lf)  I.""ItemCode"",#(lf)  I.""Dscription"" AS ""Description"",#(lf)  I.""Quantity"",#(lf)  I.""Price"",#(lf)  I.""LineTotal"",#(lf)  I.""Project"" AS ""ProjectCode"",#(lf)  I.""TaxCode"",#(lf)  H.""DocDate"" AS ""InvoiceDate"",#(lf)  H.""CardCode"" AS ""CustomerCode"",#(lf)  H.""CardName"" AS ""CustomerName"",#(lf)  CASE#(lf)    WHEN I.""ItemCode"" = 'SV002' THEN 'FSMA Contract'#(lf)    WHEN I.""ItemCode"" = 'MPS' THEN 'MPS Contract'#(lf)    WHEN I.""ItemCode"" = 'SV001' THEN 'Service Labour'#(lf)    WHEN I.""ItemCode"" = 'SV003' THEN 'Warranty'#(lf)    ELSE 'Other Service'#(lf)  END AS ""RevenueType""#(lf)FROM ""PAPERENTITY"".""OINV"" H#(lf)INNER JOIN ""PAPERENTITY"".""INV1"" I ON H.""DocEntry"" = I.""DocEntry""#(lf)WHERE I.""ItemCode"" IN ('SV001', 'SV002', 'MPS', 'SV003')")
				in
				    Source

	annotation PBI_ResultType = Table

