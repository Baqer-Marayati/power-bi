	partition Fact_ServiceCalls = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)  S.""callID"" AS ""CallID"",#(lf)  S.""createDate"" AS ""CreateDate"",#(lf)  S.""createTime"" AS ""CreateTime"",#(lf)  S.""closeDate"" AS ""CloseDate"",#(lf)  S.""closeTime"" AS ""CloseTime"",#(lf)  S.""respOnDate"" AS ""ResponseDate"",#(lf)  S.""respOnTime"" AS ""ResponseTime"",#(lf)  S.""resolOnDat"" AS ""ResolutionDate"",#(lf)  S.""resolOnTim"" AS ""ResolutionTime"",#(lf)  S.""customer"" AS ""CustomerCode"",#(lf)  S.""custmrName"" AS ""CustomerName"",#(lf)  S.""itemCode"" AS ""ItemCode"",#(lf)  S.""insID"" AS ""EquipmentKey"",#(lf)  S.""subject"" AS ""Subject"",#(lf)  S.""callType"" AS ""CallType"",#(lf)  COALESCE(CT.""Name"", 'Unclassified') AS ""CallTypeName"",#(lf)  COALESCE(S.""problemTyp"", 0) AS ""ProblemTypeID"",#(lf)  S.""origin"" AS ""Origin"",#(lf)  COALESCE(OG.""Name"", 'Unclassified') AS ""OriginName"",#(lf)  S.""priority"" AS ""Priority"",#(lf)  S.""status"" AS ""Status"",#(lf)  CASE S.""status""#(lf)    WHEN -1 THEN 'Closed'#(lf)    WHEN -2 THEN 'Pending'#(lf)    WHEN -3 THEN 'Open'#(lf)    WHEN 1 THEN 'Canceled'#(lf)    ELSE 'Unknown'#(lf)  END AS ""StatusName"",#(lf)  COALESCE(S.""assignee"", 0) AS ""AssigneeKey"",#(lf)  COALESCE(S.""responder"", 0) AS ""ResponderKey"",#(lf)  S.""userSign"" AS ""CreatedByUserKey"",#(lf)  S.""BPProjCode"" AS ""ProjectCode"",#(lf)  S.""U_A15"" AS ""CounterBK"",#(lf)  S.""U_A_20"" AS ""CounterCyan"",#(lf)  S.""U_A_21"" AS ""CounterMagenta"",#(lf)  S.""U_A_22"" AS ""CounterYellow"",#(lf)  S.""U_A_29"" AS ""TotalCounter"",#(lf)  CASE#(lf)    WHEN S.""closeDate"" IS NOT NULL AND S.""createDate"" IS NOT NULL THEN#(lf)      SECONDS_BETWEEN(#(lf)        ADD_SECONDS(S.""createDate"", FLOOR(S.""createTime""/100)*3600 + MOD(S.""createTime"",100)*60),#(lf)        ADD_SECONDS(S.""closeDate"", FLOOR(S.""closeTime""/100)*3600 + MOD(S.""closeTime"",100)*60)#(lf)      ) / 3600.0#(lf)    ELSE NULL#(lf)  END AS ""ResolutionHours"",#(lf)  CASE#(lf)    WHEN S.""respOnDate"" IS NOT NULL AND S.""createDate"" IS NOT NULL THEN#(lf)      SECONDS_BETWEEN(#(lf)        ADD_SECONDS(S.""createDate"", FLOOR(S.""createTime""/100)*3600 + MOD(S.""createTime"",100)*60),#(lf)        ADD_SECONDS(S.""respOnDate"", FLOOR(S.""respOnTime""/100)*3600 + MOD(S.""respOnTime"",100)*60)#(lf)      ) / 3600.0#(lf)    ELSE NULL#(lf)  END AS ""ResponseHours""#(lf)FROM ""CANON"".""OSCL"" S#(lf)LEFT JOIN ""CANON"".""OSCT"" CT ON S.""callType"" = CT.""callTypeID""#(lf)LEFT JOIN ""CANON"".""OSCO"" OG ON S.""origin"" = OG.""originID""")
				in
				    Source

	annotation PBI_ResultType = Table

