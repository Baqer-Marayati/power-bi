table export_ap_open_items
	lineageTag: d1452f9b-c77d-48eb-b8ee-cac88ed8f331

	column company_code
		dataType: string
		lineageTag: d1452f9b-c77d-48eb-b8ee-cac88ed8f332
		summarizeBy: none
		sourceColumn: company_code

		annotation SummarizationSetBy = Automatic

	column doc_no
		dataType: string
		lineageTag: d1452f9b-c77d-48eb-b8ee-cac88ed8f333
		summarizeBy: none
		sourceColumn: doc_no

		annotation SummarizationSetBy = Automatic

	column bp_id
		dataType: string
		lineageTag: d1452f9b-c77d-48eb-b8ee-cac88ed8f334
		summarizeBy: none
		sourceColumn: bp_id

		annotation SummarizationSetBy = Automatic

	column posting_date
		dataType: dateTime
		formatString: Long Date
		lineageTag: d1452f9b-c77d-48eb-b8ee-cac88ed8f335
		summarizeBy: none
		sourceColumn: posting_date

		annotation SummarizationSetBy = Automatic

	column due_date
		dataType: dateTime
		formatString: Long Date
		lineageTag: d1452f9b-c77d-48eb-b8ee-cac88ed8f336
		summarizeBy: none
		sourceColumn: due_date

		annotation SummarizationSetBy = Automatic

	column open_amount_lc
		dataType: double
		lineageTag: d1452f9b-c77d-48eb-b8ee-cac88ed8f337
		summarizeBy: sum
		sourceColumn: open_amount_lc

		annotation SummarizationSetBy = Automatic

	column days_overdue
		dataType: int64
		formatString: 0
		lineageTag: d1452f9b-c77d-48eb-b8ee-cac88ed8f338
		summarizeBy: none
		sourceColumn: days_overdue

		annotation SummarizationSetBy = Automatic

	partition export_ap_open_items = calculated
		mode: import
		source =
				
				SELECTCOLUMNS (
				    FILTER ( 'vendorLedgerEntries', 'vendorLedgerEntries'[open] = 1 ),
				    "company_code", "CANON",
				    "doc_no", FORMAT ( 'vendorLedgerEntries'[documentNo], "0" ),
				    "bp_id", 'vendorLedgerEntries'[vendorCode],
				    "posting_date", 'vendorLedgerEntries'[postingDate],
				    "due_date", 'vendorLedgerEntries'[dueDate],
				    "open_amount_lc", 'vendorLedgerEntries'[remainingAmount],
				    "days_overdue", MAX ( 0, DATEDIFF ( 'vendorLedgerEntries'[dueDate], TODAY (), DAY ) )
				)

	annotation PBI_ResultType = Table
