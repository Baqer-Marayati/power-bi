	partition export_journal_entries = calculated
		mode: import
		source =
				
				SELECTCOLUMNS (
				    'Fact_PNL',
				    "company_code", "PAPERENTITY",
				    "journal_no", 'Fact_PNL'[TransId],
				    "line_no", 'Fact_PNL'[LineId],
				    "posting_date", 'Fact_PNL'[PostingDate],
				    "account_code", 'Fact_PNL'[AcctCode],
				    "debit_lc", 'Fact_PNL'[Debit],
				    "credit_lc", 'Fact_PNL'[Credit],
				    "user_id", "unknown"
				)

	annotation PBI_ResultType = Table
