	partition export_item_master = calculated
		mode: import
		source =
				
				DISTINCT (
				    SELECTCOLUMNS (
				        'Fact_SalesDetail',
				        "company_code", "CANON",
				        "item_id", 'Fact_SalesDetail'[ItemCode],
				        "item_group", 'Fact_SalesDetail'[ItemGroupName],
				        "uom", BLANK (),
				        "active_flag", 1
				    )
				)

	annotation PBI_ResultType = Table
