# Copy to powerbi-api-local.env (gitignored) and fill with real values.
# Never commit powerbi-api-local.env.

PBI_TENANT_ID=your-tenant-id-guid
PBI_CLIENT_ID=your-app-client-id-guid
PBI_CLIENT_SECRET=your-client-secret-value

