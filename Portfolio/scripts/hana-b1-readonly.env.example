# Copy to hana-b1-readonly.env (gitignored) and fill with real values:
#   cp Portfolio/scripts/hana-b1-readonly.env.example Portfolio/scripts/hana-b1-readonly.env
#
# Load in shell (adjust path if cwd differs):
#   set -a && source Portfolio/scripts/hana-b1-readonly.env && set +a
#
# Never commit hana-b1-readonly.env.

HANA_HOST=hana-vm-107
HANA_PORT=30013
HANA_DATABASE=HV107C21694P01
HANA_USERNAME=your-read-only-user
HANA_PASSWORD=

# SAP Business One company schema used by Canon Inventory PBIP queries
HANA_SCHEMA=CANON

# Optional — must match ODBC DSN on machines that refresh PBIP (case may vary)
HANA_ODBC_DSN=HANA_B1

# Optional TLS (uncomment/adapt if your HANA requires encrypted client connect)
# HANA_ENCRYPT=true
# HANA_SSL_VALIDATE_CERTIFICATE=false
